{"name":"aima-exercise-forms","displayName":"AIMA Exercise Forms","description":"Render AIMA exercise questions and answers from .md/.adoc files as a form-like UI in the sidebar.","version":"0.1.1","publisher":"InquiryInstitute","license":"MIT","repository":{"type":"git","url":"https://github.com/InquiryInstitute/aima-exercise-forms.git"},"engines":{"vscode":"^1.74.0"},"categories":["Education","Other"],"activationEvents":["onView:aimaExerciseForms.panel","onCommand:aimaExerciseForms.open","workspaceContains:exercises/**/*.md"],"main":"./out/extension.js","contributes":{"commands":[{"command":"aimaExerciseForms.open","title":"AIMA: Open Exercise Form"}],"viewsContainers":{"activitybar":[{"id":"aimaExerciseForms","title":"AIMA Exercises","icon":"$(edit)"}]},"views":{"aimaExerciseForms":[{"type":"webview","id":"aimaExerciseForms.panel","name":"Exercise Form"}]},"configuration":{"title":"AIMA Exercise Forms","properties":{"aimaExerciseForms.glob":{"type":"string","default":"exercises/**/*.md","description":"Glob pattern for exercise files (relative to workspace root or aimaExerciseForms.root)."},"aimaExerciseForms.root":{"type":"string","default":"","description":"Relative path from workspace root to exercises folder. Leave empty to use workspace root."},"aimaExerciseForms.includeAdoc":{"type":"boolean","default":false,"description":"Include .adoc files in addition to .md."},"aimaExerciseForms.openOnStartup":{"type":"boolean","default":false,"description":"Open the Exercise Form view when the workspace opens (e.g. in Codespaces)."}}}},"scripts":{"vscode:prepublish":"npm run compile","compile":"tsc -p ./","watch":"tsc -watch -p ./","package":"npx --yes @vscode/vsce package --no-dependencies"},"devDependencies":{"@types/node":"^18.0.0","@types/vscode":"^1.74.0","typescript":"^5.0.0"}}